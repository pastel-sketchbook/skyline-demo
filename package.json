{
  "name": "skyline-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:data": "bun run scripts/fetch-buildings.ts",
    "dev": "vite",
    "build": "tsgo -b && vite build",
    "preview": "vite preview",
    "type-check": "tsgo -b --noEmit",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "check": "biome check --write ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "check:all": "biome check ./src && vitest run && tsgo -b --noEmit && vite build"
  },
  "dependencies": {
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@deck.gl/react": "^9.1.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "lucide-react": "^1.20.0",
    "maplibre-gl": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-map-gl": "^8.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "daisyui": "^5.0.0",
    "happy-dom": "^18.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
