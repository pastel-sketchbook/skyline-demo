{
  "name": "skyline-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:data": "bun run scripts/fetch-buildings.ts",
    "dev": "vite",
    "build": "tsgo -b && vite build",
    "preview": "vite preview",
    "type-check": "tsgo -b --noEmit",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "check": "biome check --write ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "check:all": "biome check ./src && vitest run && tsgo -b --noEmit && vite build"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.4",
    "@deck.gl/layers": "^9.3.4",
    "@deck.gl/react": "^9.3.4",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-map-gl": "^8.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260618.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "daisyui": "^5.5.23",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^7.0.1-rc",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "playwright": "^1.61.0"
  }
}
